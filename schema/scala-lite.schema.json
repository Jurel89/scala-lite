{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scala Lite Workspace Configuration",
  "type": "object",
  "properties": {
    "mode": {
      "description": "Default Scala Lite mode.",
      "default": "A",
      "oneOf": [
        {
          "type": "string",
          "enum": ["A", "B", "C"]
        },
        {
          "type": "object",
          "description": "Legacy object form.",
          "properties": {
            "default": {
              "type": "string",
              "enum": ["A", "B", "C"],
              "default": "A"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "moduleFolder": {
      "type": "string",
      "description": "Relative module folder path used for Mode C indexing.",
      "default": ""
    },
    "indexedModuleFolder": {
      "type": "string",
      "description": "Legacy alias for moduleFolder.",
      "default": ""
    },
    "profiles": {
      "type": "array",
      "description": "Task profile definitions for run/test command templates.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "buildTool",
          "workingDirectory",
          "runCommand",
          "testCommand",
          "envVars",
          "jvmOpts",
          "preBuildCommand"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "buildTool": {
            "type": "string",
            "enum": ["sbt", "mill", "scala-cli", "maven", "gradle", "none"]
          },
          "workingDirectory": {
            "type": "string"
          },
          "runCommand": {
            "type": "string"
          },
          "testCommand": {
            "type": "string"
          },
          "envVars": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "jvmOpts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preBuildCommand": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "activeProfile": {
      "type": "string",
      "description": "Profile name to use by default for run/test commands.",
      "default": ""
    },
    "ignorePatterns": {
      "type": "array",
      "description": "Additional glob ignore patterns. Prefix with ! to remove default/removable ignores.",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "unsafeMode": {
      "type": "boolean",
      "description": "Allows removal of hard safety ignore patterns.",
      "default": false
    },
    "budgets": {
      "type": "object",
      "description": "Execution budgets for search/index operations.",
      "properties": {
        "searchTimeMs": {
          "type": "integer",
          "minimum": 50,
          "default": 2000
        },
        "indexTimeMs": {
          "type": "integer",
          "minimum": 50,
          "default": 5000
        },
        "maxSearchResults": {
          "type": "integer",
          "minimum": 1,
          "default": 500
        },
        "formatterTimeMs": {
          "type": "integer",
          "minimum": 50,
          "default": 5000
        },
        "indexBatchSize": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 100,
          "description": "Number of files processed per indexing batch in Mode C/native sync."
        },
        "memory": {
          "type": "object",
          "description": "Optional memory budget caps in megabytes (upper bounds applied to computed budgets).",
          "properties": {
            "heapMb": {
              "type": "integer",
              "minimum": 1
            },
            "nativeMb": {
              "type": "integer",
              "minimum": 1
            },
            "totalMb": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "object",
      "description": "Diagnostics collection behavior.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "trigger": {
          "type": "string",
          "enum": ["onSave", "onType"],
          "default": "onSave"
        }
      },
      "additionalProperties": false
    },
    "formatter": {
      "type": "object",
      "description": "Scalafmt execution settings.",
      "properties": {
        "scalafmtPath": {
          "type": "string",
          "default": ""
        },
        "path": {
          "type": "string",
          "description": "Legacy alias for scalafmtPath.",
          "default": ""
        },
        "useDocker": {
          "type": "boolean",
          "default": false
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 100,
          "default": 5000
        },
        "formatOnSave": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "linter": {
      "type": "object",
      "description": "Scalafix execution settings.",
      "properties": {
        "scalafixPath": {
          "type": "string",
          "default": ""
        },
        "path": {
          "type": "string",
          "description": "Legacy alias for scalafixPath.",
          "default": ""
        },
        "useDocker": {
          "type": "boolean",
          "default": false
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 100,
          "default": 10000
        }
      },
      "additionalProperties": false
    },
    "deps": {
      "type": "object",
      "description": "Dependency indexing and classpath navigation settings.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "includeInWorkspaceSymbol": {
          "type": "boolean",
          "default": false
        },
        "indexTestScope": {
          "type": "boolean",
          "default": false
        },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": false
        },
        "indexCaps": {
          "type": "object",
          "properties": {
            "maxJars": {
              "type": "integer",
              "minimum": 1,
              "maximum": 2000,
              "default": 500
            },
            "maxIndexTimeSeconds": {
              "type": "integer",
              "minimum": 10,
              "maximum": 600,
              "default": 120
            }
          },
          "additionalProperties": false
        },
        "jdkModules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["java.base"]
        }
      },
      "additionalProperties": false
    },
    "build": {
      "type": "object",
      "description": "Build tool settings used for classpath and dependency commands.",
      "properties": {
        "classpathProvider": {
          "type": "string",
          "enum": ["auto", "maven", "sbt"],
          "default": "auto"
        },
        "jdkHome": {
          "type": "string",
          "default": ""
        },
        "maven": {
          "type": "object",
          "properties": {
            "profiles": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "wrapperPath": {
              "type": "string",
              "default": ""
            }
          },
          "additionalProperties": false
        },
        "sbt": {
          "type": "object",
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "strategy": {
              "type": "string",
              "enum": ["auto", "coursier", "sbt-show"],
              "default": "sbt-show"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "workspaceDoctor": {
      "type": "object",
      "description": "Workspace Doctor execution settings.",
      "properties": {
        "autoRunOnOpen": {
          "type": "boolean",
          "description": "When enabled, Workspace Doctor runs automatically 30 seconds after opening the workspace (skipped for workspaces with >10,000 files).",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "logLevel": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARN", "ERROR"],
      "default": "INFO"
    },
    "testFrameworkHints": {
      "type": "array",
      "description": "Optional test framework hints used by test discovery.",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "additionalProperties": true
}

{
  "name": "scala-lite",
  "displayName": "Scala Lite",
  "description": "Lightweight Scala extension for VS Code with fast navigation, run/test workflows, formatting, and workspace diagnostics.",
  "version": "0.0.1",
  "publisher": "jurel89",
  "preview": true,
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://github.com/Jurel89/scala-lite/actions/workflows/ci.yml/badge.svg",
      "href": "https://github.com/Jurel89/scala-lite/actions/workflows/ci.yml",
      "description": "CI Status"
    },
    {
      "url": "https://img.shields.io/badge/license-MIT-green.svg",
      "href": "https://github.com/Jurel89/scala-lite/blob/main/LICENSE",
      "description": "MIT License"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jurel89/scala-lite.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "scala",
    "sbt",
    "mill",
    "scala-cli",
    "formatter"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:scala",
    "workspaceContains:**/*.scala",
    "workspaceContains:**/*.sbt",
    "workspaceContains:**/build.sc"
  ],
  "contributes": {
    "commands": [
      {
        "command": "scalaLite.runIdleCpuAudit",
        "title": "%command.scalaLite.runIdleCpuAudit.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.reDetectBuildTool",
        "title": "%command.scalaLite.reDetectBuildTool.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.pickWorkspaceMode",
        "title": "%command.scalaLite.pickWorkspaceMode.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.switchModeA",
        "title": "%command.scalaLite.switchModeA.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.switchModeB",
        "title": "%command.scalaLite.switchModeB.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.switchModeC",
        "title": "%command.scalaLite.switchModeC.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.runMainEntry",
        "title": "%command.scalaLite.runMainEntry.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.copyRunCommand",
        "title": "%command.scalaLite.copyRunCommand.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.debugMainEntry",
        "title": "%command.scalaLite.debugMainEntry.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.generateDebugConfiguration",
        "title": "%command.scalaLite.generateDebugConfiguration.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.runTestSuite",
        "title": "%command.scalaLite.runTestSuite.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.runTestCase",
        "title": "%command.scalaLite.runTestCase.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.copyTestCommand",
        "title": "%command.scalaLite.copyTestCommand.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.copyDiagnosticBundle",
        "title": "%command.scalaLite.copyDiagnosticBundle.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.switchProfile",
        "title": "%command.scalaLite.switchProfile.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.editProfiles",
        "title": "%command.scalaLite.editProfiles.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.openConfiguration",
        "title": "%command.scalaLite.openConfiguration.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.createConfiguration",
        "title": "%command.scalaLite.createConfiguration.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.rebuildIndex",
        "title": "%command.scalaLite.rebuildIndex.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.runScalafix",
        "title": "%command.scalaLite.runScalafix.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.runWorkspaceDoctor",
        "title": "%command.scalaLite.runWorkspaceDoctor.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.restartNativeEngine",
        "title": "%command.scalaLite.restartNativeEngine.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.runActivationAudit",
        "title": "%command.scalaLite.runActivationAudit.title%",
        "category": "%commandCategory.scalaLite%"
      },
      {
        "command": "scalaLite.runMemoryBudgetAudit",
        "title": "%command.scalaLite.runMemoryBudgetAudit.title%",
        "category": "%commandCategory.scalaLite%"
      }
    ],
    "configuration": {
      "title": "Scala Lite",
      "properties": {
        "scalaLite.mode": {
          "type": "string",
          "enum": [
            "A",
            "B",
            "C"
          ],
          "default": "A",
          "description": "%configuration.scalaLite.mode.description%"
        },
        "scalaLite.logLevel": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ],
          "default": "INFO",
          "description": "%configuration.scalaLite.logLevel.description%"
        },
        "scalaLite.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.scalaLite.diagnostics.enabled.description%"
        },
        "scalaLite.diagnostics.trigger": {
          "type": "string",
          "enum": [
            "onSave",
            "onType"
          ],
          "default": "onSave",
          "description": "%configuration.scalaLite.diagnostics.trigger.description%"
        },
        "scalaLite.formatter.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.scalaLite.formatter.formatOnSave.description%"
        },
        "scalaLite.activeProfile": {
          "type": "string",
          "default": "",
          "description": "%configuration.scalaLite.activeProfile.description%"
        }
      }
    },
    "languages": [
      {
        "id": "scala",
        "aliases": [
          "Scala"
        ],
        "extensions": [
          ".scala",
          ".sc"
        ],
        "configuration": "./syntaxes/scala-language-configuration.json"
      },
      {
        "id": "scala-sbt",
        "aliases": [
          "Scala SBT"
        ],
        "extensions": [
          ".sbt"
        ],
        "configuration": "./syntaxes/scala-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "scala",
        "scopeName": "source.scala",
        "path": "./syntaxes/scala.tmLanguage.json"
      },
      {
        "language": "scala-sbt",
        "scopeName": "source.scala.sbt",
        "path": "./syntaxes/sbt.tmLanguage.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": [
          "/.vscode/scala-lite.json"
        ],
        "url": "./schema/scala-lite.schema.json"
      }
    ]
  },
  "scripts": {
    "clean": "rm -rf dist",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "native:build": "cargo build --manifest-path native/scala-lite-engine/Cargo.toml --release",
    "native:build:napi": "(cd native/scala-lite-engine && napi build --platform --release --features napi)",
    "native:test": "cargo test --manifest-path native/scala-lite-engine/Cargo.toml",
    "pretest": "npm run compile",
    "test": "node --test dist/test/*.test.js",
    "test:smoke": "node dist/test/smoke.vscode-test.js"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "minimatch": "^10.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.5.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "typescript": "^5.8.2"
  }
}

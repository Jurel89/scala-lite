{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scala Lite Workspace Configuration",
  "type": "object",
  "properties": {
    "mode": {
      "type": "object",
      "properties": {
        "default": {
          "type": "string",
          "enum": ["A", "B", "C"]
        }
      },
      "additionalProperties": true
    },
    "indexedModuleFolder": {
      "type": "string"
    },
    "logLevel": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARN", "ERROR"]
    },
    "formatter": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "useDocker": { "type": "boolean", "default": false },
        "timeoutMs": { "type": "integer", "minimum": 100, "default": 5000 },
        "formatOnSave": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "linter": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "useDocker": { "type": "boolean", "default": false },
        "timeoutMs": { "type": "integer", "minimum": 100, "default": 10000 }
      },
      "additionalProperties": false
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "buildTool",
          "workingDirectory",
          "runCommand",
          "testCommand",
          "envVars",
          "jvmOpts",
          "preBuildCommand"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "buildTool": {
            "type": "string",
            "enum": ["sbt", "mill", "scala-cli", "maven", "gradle", "none"]
          },
          "workingDirectory": { "type": "string" },
          "runCommand": { "type": "string" },
          "testCommand": { "type": "string" },
          "envVars": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "jvmOpts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "preBuildCommand": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
